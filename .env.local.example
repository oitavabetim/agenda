# ============================================
# OITAVA IGREJA AGENDA - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha com os valores reais
# NUNCA commit o arquivo .env.local no repositório

# ============================================
# NEXTAUTH (Autenticação)
# ============================================
# URL base da aplicação (mudar em produção)
NEXTAUTH_URL=http://localhost:3000

# Secret para criptografia de sessões (gerar com: openssl rand -base64 32)
NEXTAUTH_SECRET=

# ============================================
# GOOGLE SERVICE ACCOUNT
# ============================================
# E-mail da Service Account do Google Cloud
GOOGLE_SERVICE_ACCOUNT_EMAIL=agenda@oitavabetim.iam.gserviceaccount.com

# Private Key da Service Account
# Formato: "-----BEGIN PRIVATE KEY-----\nCHAVE\n-----END PRIVATE KEY-----\n"
# Substitua as quebras de linha reais por \n
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# ID do Projeto Google Cloud
GOOGLE_CALENDAR_PROJECT_ID=oitavabetim

# ============================================
# CONFIGURAÇÕES DE TENANT (MVP)
# ============================================
# Identificador do tenant padrão
DEFAULT_TENANT_ID=oitava-betim-agenda

# IDs das agendas do Google Calendar por espaço (preencher com os IDs reais)
# Cada espaço deve ter uma agenda separada no Google Calendar
# Para obter: Configurações da agenda > ID da agenda
CALENDAR_ID_TEMPLO=
CALENDAR_ID_SALAO_SOCIAL=
CALENDAR_ID_SALA_A=
CALENDAR_ID_SALA_B=
CALENDAR_ID_SALA_01=
CALENDAR_ID_SALA_02=
CALENDAR_ID_SALA_03=
CALENDAR_ID_SALA_04=
CALENDAR_ID_SALA_05=
CALENDAR_ID_SALA_07=
CALENDAR_ID_SALA_APOIO=

# URL do iframe da agenda geral (Google Calendar público)
# Para obter: Calendar > Configurações > URL pública da agenda > Incorporar código
# Copie apenas a URL do atributo src do iframe
NEXT_PUBLIC_CALENDAR_IFRAME_URL=https://calendar.google.com/calendar/embed?src=SEU_CALENDAR_ID

# URL do mapa da igreja (imagem em public/images/mapas/)
# Para adicionar novo mapa: coloque a imagem em public/images/mapas/ e atualize aqui
MAPA_URL=/images/mapas/mapa-oitava.jpg

# ============================================
# ADICIONANDO NOVA IGREJA (Multi-Tenant)
# ============================================
# Para adicionar uma nova igreja, edite src/lib/tenant/config.ts e adicione:
#
# "nome-da-igreja": {
#   id: "nome-da-igreja",
#   name: "Nome da Igreja",
#   googleClientId: process.env.GOOGLE_CLIENT_ID || "",
#   googleClientSecret: process.env.GOOGLE_CLIENT_SECRET || "",
#   calendarIframeUrl: process.env.CALENDAR_IFRAME_URL || "",
#   mapaUrl: process.env.MAPA_URL || "/images/mapas/mapa-nova-igreja.jpg",
#   espacos: [
#     {
#       id: "templo",
#       nome: "Templo",
#       descricao: "Espaço principal",
#       capacidade: null,
#       calendarId: process.env.NOVA_IGREJA_CALENDAR_ID_TEMPLO || "",
#       ativo: true,
#     },
#     // ... mais espaços
#   ],
# }
#
# E adicione as variáveis de ambiente correspondentes abaixo:

# ============================================
# CONFIGURAÇÕES GERAIS
# ============================================
# Node environment
NODE_ENV=development
